{
  "nodeModulesDir": "auto",
  "lint": {
    "rules": { "tags": ["recommended"] }
  },
  "compilerOptions": {
    "jsx": "precompile",
    "jsxImportSource": "@hono/hono/jsx"
  },
  "imports": {
    "@hono/hono": "jsr:@hono/hono@^4.12.18",
    "open": "npm:open@^11.0.0",
    "patchright": "npm:patchright@^1.61.1"
  },
  "tasks": {
    "browser:install": "deno run -A npm:patchright install chromium",
    "browser:open": "deno run -A browser/open.ts",
    "browser:smoke": "deno run -A browser/smoke.ts"
  }
}
